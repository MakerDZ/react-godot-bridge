{
  "name": "react-godot-bridge",
  "version": "1.0.5",
  "description": "Bidirectional, event-driven bridge between React and a Godot WebAssembly game running in an iframe. Socket.io-style API.",
  "keywords": ["godot", "react", "nextjs", "webassembly", "wasm", "game", "bridge", "iframe", "postmessage"],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/MakerDZ/react-godot-bridge"
  },
  "homepage": "https://github.com/MakerDZ/react-godot-bridge#readme",
  "bugs": {
    "url": "https://github.com/MakerDZ/react-godot-bridge/issues"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@types/react": "^19",
    "tsup": "^8",
    "typescript": "^5"
  }
}
